{
  "name": "portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/fetch-sanity-content.mjs && vite build && node scripts/prerender.mjs",
    "build:client": "vite build",
    "test:analytics": "node --test scripts/vercel-analytics.test.mjs scripts/posthog-analytics.test.mjs scripts/analytics-alignment.test.mjs",
    "test:cases": "node --test scripts/case-narrative.test.mjs",
    "test:ui": "node --test scripts/header-responsive.test.mjs",
    "test:seo": "node --test scripts/seo-indexing.test.mjs scripts/seo-metadata.test.mjs",
    "sanity:content": "node scripts/fetch-sanity-content.mjs",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "studio": "sanity dev",
    "studio:build": "sanity build --output-path dist-studio",
    "sanity:seed": "node sanity/seed/seed.mjs"
  },
  "dependencies": {
    "@lisse/react": "^0.4.0",
    "@posthog/react": "^1.9.1",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@web-kits/audio": "^0.1.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "motion": "^12.40.0",
    "posthog-js": "^1.376.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanity": "^5.26.0",
    "styled-components": "^6.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@sparticuz/chromium": "^147.0.0",
    "puppeteer": "^24.43.1",
    "sirv": "^3.0.2"
  }
}
